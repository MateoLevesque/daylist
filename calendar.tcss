Todolist {
  layout: vertical;
  align: center middle;
  height: 100%;
  width: 2fr;
  background: black;
}

#calendar {
  layout: vertical;
  align: center middle;
  height: 100%;
  width: 1fr;
}

#calendar_section_title {
  padding-bottom: 1;
}

.hint_cal {
  color: rgba(255, 255, 255, 0.2);
  padding-top: 2;
  padding-bottom: 2;
}

#task_input {
  display: none;
  dock: bottom;
}

#task_input:focus {
  display: block;
}
